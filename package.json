{
  "name": "agent-spec-starter",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:ui\" \"npm run dev:agent\" --names ui,agentspecagent --prefix-colors blue,green --kill-others",
    "dev:debug": "LOG_LEVEL=debug npm run dev",
    "dev:agent": "./scripts/run-agent.sh",
    "dev:ui": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "install:agent": "./scripts/setup-agent.sh",
    "postinstall": "npm run install:agent"
  },
  "dependencies": {
    "@a2ui/lit": "^0.8.1",
    "@ag-ui/a2ui-middleware": "file:../ag-ui/middlewares/a2ui-middleware",
    "@ag-ui/agent-spec": "file:../ag-ui/integrations/agent-spec/typescript",
    "@ag-ui/core": "file:../ag-ui/sdks/typescript/packages/core",
    "@ag-ui/client": "file:../ag-ui/sdks/typescript/packages/client",
    "@ag-ui/encoder": "file:../ag-ui/sdks/typescript/packages/encoder",
    "@ag-ui/proto": "file:../ag-ui/sdks/typescript/packages/proto",
    "@copilotkit/a2ui-renderer": "1.51.3",
    "@copilotkit/react-core": "1.51.3",
    "@copilotkit/react-ui": "1.51.3",
    "@copilotkit/runtime": "1.51.3",
    "@copilotkit/runtime-client-gql": "1.51.3",
    "@copilotkit/shared": "1.51.3",
    "hono": "^4.11.4",
    "next": "16.0.10",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "zod": "^3.25.75"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.13",
    "@types/node": "^22.15.3",
    "@types/react": "19.2.3",
    "@types/react-dom": "19.2.3",
    "eslint": "^9.34.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.1.13",
    "typescript": "5.9.2",
    "concurrently": "^9.2.1",
    "eslint-config-next": "15.3.2"
  },
  "pnpm": {
    "overrides": {
      "@ag-ui/encoder": "file:../ag-ui/sdks/typescript/packages/encoder",
      "@ag-ui/core": "file:../ag-ui/sdks/typescript/packages/core",
      "@ag-ui/proto": "file:../ag-ui/sdks/typescript/packages/proto"
    }
  },
  "resolutions": {}
}
